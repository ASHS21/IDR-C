# =============================================================================
# Identity Radar — Environment Variables
# Copy this file to .env.local and fill in the values.
# The setup script (scripts/setup.sh) will auto-generate secrets for you.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL Database
# ---------------------------------------------------------------------------
# Used by Docker Compose to create the database
POSTGRES_DB=identity_radar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Connection string used by Drizzle ORM and the application
# For local dev:  postgresql://postgres:<password>@localhost:5432/identity_radar
# For Docker:     postgresql://postgres:<password>@db:5432/identity_radar
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/identity_radar

# ---------------------------------------------------------------------------
# NextAuth.js
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-random-secret-here

# The canonical URL of the application (used for OAuth callbacks, etc.)
# Local dev: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# AI Providers
# The AI engine tries providers in order: Ollama -> Anthropic -> Deterministic
# ---------------------------------------------------------------------------

# Ollama — local LLM (recommended for dev, no API key needed)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Anthropic — cloud LLM (optional; used as fallback if Ollama unavailable)
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# SMTP Email (optional — for notification emails)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Identity Radar <noreply@identityradar.io>

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Production: Caddy / Domain (used by docker-compose.prod.yml)
# ---------------------------------------------------------------------------
# Set to your FQDN for automatic Let's Encrypt HTTPS
# DOMAIN=radar.example.com
