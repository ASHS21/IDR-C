# =============================================================================
# Identity Radar — Production environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env` on the server (NEVER commit the real .env):
#     cp .env.production.example .env && nano .env
# Then start the stack:
#     docker compose -f docker/docker-compose.prod.yml up -d --build
# =============================================================================

# ── Database (used by the db + app containers) ───────────────────────────────
POSTGRES_DB=identity_radar
POSTGRES_USER=postgres
# REQUIRED — set a strong password. The app builds DATABASE_URL from these.
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# REQUIRED — generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_32
# Public URL users hit (must match the domain Caddy serves).
NEXTAUTH_URL=https://radar.example.com
NEXT_PUBLIC_APP_URL=https://radar.example.com
# Required when behind the Caddy reverse proxy.
AUTH_TRUST_HOST=true

# ── Cron authentication (REQUIRED in production) ─────────────────────────────
# Bearer token that guards the 16 /api/cron/* scanner endpoints. If left unset,
# those endpoints are DENIED in production (fail-closed). Set a strong random
# value and use it in your scheduler:  Authorization: Bearer <CRON_SECRET>
# Generate with:  openssl rand -base64 32
CRON_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# Show demo login credentials on the sign-in page — MUST be false in production.
NEXT_PUBLIC_DEMO_MODE=false

# ── Domain (Caddy auto-HTTPS via Let's Encrypt) ──────────────────────────────
# Use a real hostname for public TLS, or "localhost" for a local/self-signed run.
DOMAIN=radar.example.com

# ── AI provider (OPTIONAL — leave both blank to disable AI features) ──────────
# Air-gapped: run Ollama on the host/network and point OLLAMA_URL at it, e.g.
#   OLLAMA_URL=http://host.docker.internal:11434
# Online: set ANTHROPIC_API_KEY instead (prompts leave the box — do NOT use
# in a sovereign / air-gapped deployment).
OLLAMA_URL=
OLLAMA_MODEL=qwen2.5:7b
ANTHROPIC_API_KEY=

# ── Email notifications (OPTIONAL) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Identity Radar <noreply@identityradar.local>
